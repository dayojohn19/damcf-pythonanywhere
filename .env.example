# Copy to .env (this file is gitignored) and fill values.
# Elastic Email SMTP
SMTP_HOST=smtp.elasticemail.com
SMTP_PORT=587
SMTP_USER=dayo_john16@yahoo.com
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Where contact form emails are delivered
CONTACT_TO_EMAIL=dayo_john16@yahoo.com
DEFAULT_FROM_EMAIL=dayo_john16@yahoo.com

# Media uploads (Cloudinary)
USE_CLOUDINARY=1
# You can set either the 3 vars below or CLOUDINARY_URL
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
